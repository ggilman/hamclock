# HamClock Docker Compose Configuration
# Edit these values to customize your deployment

# Alpine Linux version
ALPINE_TAG=3.23.3

# HamClock version
HAMCLOCK_VERSION=1.42

# Resolutions to build (comma-separated)
BUILD_RESOLUTIONS=800x480,1600x960,2400x1440,3200x1920

# Runtime configuration
TZ=UTC
PUID=0
PGID=0
PORT=8081

# Backend Configuration (choose ONE method):
# Leave both empty to use HamClock's default behavior

# Option 1: Use a preset backend
# Uncomment ONE of these:
#BACKEND_PRESET=hamclock     # W4BAE's hamclock.com (recommended)
#BACKEND_PRESET=ohb          # Open HamClock Backend
#BACKEND_PRESET=original     # Original server (deprecated June 2026)
BACKEND_PRESET=

# Option 2: Specify a custom backend URL (takes priority over BACKEND_PRESET)
# Format: hostname:port or just hostname (defaults to port 80)
# Examples:
#BACKEND_URL=hamclock.com:80
#BACKEND_URL=192.168.1.100:8080
#BACKEND_URL=ohb.hamclock.app:80
BACKEND_URL=
